<Window x:Class="AuditHistoryExtractorPro.Desktop.Views.QuickExtractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quick Audit Extract" Height="520" Width="820">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <StackPanel.Resources>
                <Style TargetType="FrameworkElement">
                    <Setter Property="Margin" Value="0,0,8,0" />
                </Style>
            </StackPanel.Resources>
            <TextBlock Text="Entidad:" VerticalAlignment="Center"/>
            <TextBox Width="180" Text="{Binding EntityName, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <DatePicker SelectedDate="{Binding StartDate}" Width="140"/>
            <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <DatePicker SelectedDate="{Binding EndDate}" Width="140"/>
            <TextBlock Text="Máx:" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <TextBox Width="80" Text="{Binding MaxRows}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <StackPanel.Resources>
                <Style TargetType="FrameworkElement">
                    <Setter Property="Margin" Value="0,0,12,0" />
                </Style>
            </StackPanel.Resources>
            <CheckBox Content="Create" IsChecked="{Binding IncludeCreate}"/>
            <CheckBox Content="Update" IsChecked="{Binding IncludeUpdate}"/>
            <CheckBox Content="Delete" IsChecked="{Binding IncludeDelete}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <StackPanel.Resources>
                <Style TargetType="FrameworkElement">
                    <Setter Property="Margin" Value="0,0,8,0" />
                </Style>
            </StackPanel.Resources>
            <Button Command="{Binding ExtractCommand}" Padding="12,6">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Extraer"/>
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Content" Value="Extrayendo..."/>
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Command="{Binding CancelCommand}" Padding="12,6">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Cancelar"/>
                        <Setter Property="IsEnabled" Value="False"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="IsEnabled" Value="True"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <ProgressBar Width="200" Height="16" Minimum="0" Maximum="100"
                         Value="{Binding ProgressValue}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  EnableRowVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="AuditId" Binding="{Binding AuditId}" Width="120"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedOn}" Width="140"/>
                <DataGridTextColumn Header="Entidad" Binding="{Binding EntityName}" Width="120"/>
                <DataGridTextColumn Header="Usuario" Binding="{Binding UserName}" Width="150"/>
                <DataGridTextColumn Header="Operación" Binding="{Binding Operation}" Width="120"/>
                <DataGridTextColumn Header="Campo" Binding="{Binding ChangedField}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
            <StackPanel.Resources>
                <Style TargetType="FrameworkElement">
                    <Setter Property="Margin" Value="0,0,8,0" />
                </Style>
            </StackPanel.Resources>
            <ProgressBar Width="160" Height="10" Minimum="0" Maximum="100" Value="{Binding ProgressValue}"/>
            <TextBlock Text="{Binding ProgressValue, StringFormat='Progress: {0}%'}"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="12,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
